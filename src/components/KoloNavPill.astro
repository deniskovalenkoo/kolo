---
// Bottom floating Liquid-Glass navigation — replaces the default Webflow nav.
//
// Visual: iOS 26-style Liquid Glass — strong backdrop blur, saturated colour
// pickup from the page behind, soft light reflection on the top edge, layered
// inset shadows for depth.
//
// Content: matches the original Webflow nav exactly — just the logo, the
// "Get Kolo card" CTA, and a hamburger that expands a small panel containing
// the QR-download block.  No extra menu items added.
//
// Anchors to the bottom of the viewport (matching the original Webflow layout)
// and the dropdown panel opens UPWARD.
//
// Mounted as a slot child of WebflowPage so the original Webflow nav classes
// are hidden via the global style block below (is:inline so the rule lands
// in the HTML directly, beating Webflow's inline `style="display:flex"`).

interface Props {
  langPrefix?: string;
  ctaLabel?: string;
}

const { langPrefix = '', ctaLabel = 'Get Kolo card' } = Astro.props;
---

<!-- Hide the original Webflow nav. is:inline ensures these rules end up in the
     HTML and beat Webflow's inline `style="display:flex"` via !important. -->
<style is:inline>
  .n-menu-wrap,
  .n-menu-animation-wrap,
  .n-menu-bg,
  .n-menu-body-wrap,
  .n-menu-container,
  .n-cta-animation { display: none !important; }
</style>

<!-- SVG displacement filter for the Liquid Glass refraction.  Safari and
     Chromium with `backdrop-filter: url()` support pick this up; other
     browsers fall back to the multi-layer gradient + blur (still glassy). -->
<svg class="kolo-nav__svg" aria-hidden="true" focusable="false">
  <defs>
    <filter id="kolo-liquid-glass" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.012 0.012" numOctaves="2" seed="42" result="turb"/>
      <feDisplacementMap in="SourceGraphic" in2="turb" scale="22" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>
</svg>

<nav class="kolo-nav" data-state="closed" aria-label="Main">
  <div class="kolo-nav__panel" role="menu" aria-hidden="true">
    <div class="kolo-nav__panel-inner">
      <div class="kolo-nav__panel-qr">
        <img
          src="/cdn/641863621e81371558abea11/689f2de63b1d3a4d1eb4df6b_qr_code.svg"
          alt="Download Kolo app — QR code"
          width="120"
          height="120"
        />
        <div class="kolo-nav__panel-text">
          <p class="kolo-nav__panel-title">Get the app</p>
          <p class="kolo-nav__panel-sub">Scan with your phone — iOS or Android</p>
        </div>
      </div>
    </div>
  </div>

  <div class="kolo-nav__pill">
    <a class="kolo-nav__logo" href={`${langPrefix}/`} aria-label="Kolo home">
      <img
        src="/cdn/641863621e81371558abea11/682dac7e7b0e8bf65f4f72be_logo-white.svg"
        alt="Kolo"
        height="20"
      />
    </a>

    <a class="kolo-nav__cta" href="#">{ctaLabel}</a>

    <button class="kolo-nav__toggle" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</nav>

<style>
  :root {
    --glass-bg: rgba(255, 255, 255, 0.04);
    --glass-bg-hi: rgba(255, 255, 255, 0.16);
    --glass-text: rgba(255, 255, 255, 0.95);
    --glass-text-mute: rgba(255, 255, 255, 0.7);
    --glass-cta-bg: #fff;
    --glass-cta-fg: #0a0a0c;
    --glass-radius: 999px;
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .kolo-nav__svg {
    position: fixed;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .kolo-nav {
    position: fixed;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    z-index: 2147483647;
    font-family: 'Poppins', system-ui, -apple-system, sans-serif;
    width: max-content;
    max-width: calc(100vw - 24px);
  }

  /* ---------- The pill itself: iOS Liquid Glass ---------- */

  .kolo-nav__pill {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 6px 6px 22px;
    border-radius: var(--glass-radius);

    /* Multi-stop linear gradient gives the impression of light refracting
       through the glass — brighter at top-left, darker at bottom-right. */
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.22) 0%,
        rgba(255, 255, 255, 0.06) 40%,
        rgba(255, 255, 255, 0.04) 60%,
        rgba(255, 255, 255, 0.14) 100%
      );

    backdrop-filter: blur(40px) saturate(220%) brightness(1.08);
    -webkit-backdrop-filter: blur(40px) saturate(220%) brightness(1.08);

    /* True liquid-glass refraction in browsers that support url() backdrop filters. */
    /* Comment back in if you want the SVG distortion: */
    /* backdrop-filter: blur(40px) saturate(220%) url('#kolo-liquid-glass'); */

    border: 1px solid transparent;
    background-clip: padding-box;

    /* Layered shadows: outer drop, inner top-edge highlight, inner bottom-edge shadow */
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.14) inset,        /* top highlight */
      0 -1px 0 rgba(0, 0, 0, 0.20) inset,             /* bottom inner shadow */
      0 16px 40px -8px rgba(0, 0, 0, 0.45),           /* main lift shadow */
      0 4px 14px -2px rgba(0, 0, 0, 0.30);            /* close shadow */

    transition: transform 0.4s var(--ease-out), background 0.3s ease;
  }

  /* Highlight ring around the pill — gradient border via pseudo */
  .kolo-nav__pill::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.45) 0%,
      rgba(255, 255, 255, 0.10) 30%,
      rgba(255, 255, 255, 0.05) 60%,
      rgba(255, 255, 255, 0.30) 100%
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  /* Specular sheen — bright streak at the top edge */
  .kolo-nav__pill::after {
    content: '';
    position: absolute;
    top: 1px;
    left: 14px;
    right: 14px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%
    );
    pointer-events: none;
    border-radius: inherit;
  }

  /* ---------- Pill contents ---------- */

  .kolo-nav__logo img { display: block; height: 20px; width: auto; }

  .kolo-nav__cta {
    background: var(--glass-cta-bg);
    color: var(--glass-cta-fg);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 999px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    line-height: 1;
    margin-left: 16px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 -1px 0 rgba(0, 0, 0, 0.06) inset,
      0 4px 12px -2px rgba(0, 0, 0, 0.25);
  }
  .kolo-nav__cta:hover {
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 -1px 0 rgba(0, 0, 0, 0.06) inset,
      0 8px 20px -4px rgba(255, 255, 255, 0.18);
  }

  .kolo-nav__toggle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--glass-text);
    cursor: pointer;
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .kolo-nav__toggle:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  .kolo-nav__toggle span {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--glass-text);
    border-radius: 2px;
    transition: transform 0.3s var(--ease-out), opacity 0.2s ease;
  }
  .kolo-nav[data-state='open'] .kolo-nav__toggle span:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }
  .kolo-nav[data-state='open'] .kolo-nav__toggle span:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ---------- The dropdown panel (opens UPWARD) ---------- */

  .kolo-nav__panel {
    position: absolute;
    bottom: calc(100% + 14px);
    right: 0;
    width: min(360px, calc(100vw - 32px));
    border-radius: 24px;
    padding: 20px;

    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.20) 0%,
        rgba(255, 255, 255, 0.06) 40%,
        rgba(255, 255, 255, 0.04) 60%,
        rgba(255, 255, 255, 0.14) 100%
      );
    backdrop-filter: blur(50px) saturate(220%) brightness(1.06);
    -webkit-backdrop-filter: blur(50px) saturate(220%) brightness(1.06);

    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.18) inset,
      0 -1px 0 rgba(0, 0, 0, 0.20) inset,
      0 24px 60px -8px rgba(0, 0, 0, 0.55);

    opacity: 0;
    transform: translateY(8px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);
  }
  .kolo-nav__panel::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.40) 0%,
      rgba(255, 255, 255, 0.08) 50%,
      rgba(255, 255, 255, 0.25) 100%
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  .kolo-nav[data-state='open'] .kolo-nav__panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .kolo-nav__panel-qr {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .kolo-nav__panel-qr img {
    background: #fff;
    border-radius: 12px;
    padding: 8px;
    width: 96px;
    height: 96px;
    flex-shrink: 0;
  }
  .kolo-nav__panel-text { display: flex; flex-direction: column; gap: 4px; }
  .kolo-nav__panel-title {
    color: var(--glass-text);
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .kolo-nav__panel-sub {
    color: var(--glass-text-mute);
    font-size: 13px;
    margin: 0;
    line-height: 1.5;
  }

  /* ---------- Mobile ---------- */

  @media (max-width: 600px) {
    .kolo-nav { bottom: 16px; }
    .kolo-nav__pill { padding: 6px 6px 6px 16px; gap: 6px; }
    .kolo-nav__cta { padding: 9px 14px; font-size: 13px; margin-left: 10px; }
    .kolo-nav__panel { width: calc(100vw - 32px); right: 50%; transform: translateX(50%) translateY(8px) scale(0.97); }
    .kolo-nav[data-state='open'] .kolo-nav__panel {
      transform: translateX(50%) translateY(0) scale(1);
    }
  }
</style>

<script is:inline>
  (() => {
    const nav = document.querySelector('.kolo-nav');
    if (!nav) return;
    const toggle = nav.querySelector('.kolo-nav__toggle');
    const panel = nav.querySelector('.kolo-nav__panel');

    function setState(open) {
      nav.dataset.state = open ? 'open' : 'closed';
      if (toggle) toggle.setAttribute('aria-expanded', String(open));
      if (panel) panel.setAttribute('aria-hidden', String(!open));
    }

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      setState(nav.dataset.state !== 'open');
    });

    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target)) setState(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setState(false);
    });
  })();
</script>

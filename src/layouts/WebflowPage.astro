---
// Renders a 1:1 mirror of an original Webflow page.
// Takes the full HTML string scraped from kolo.xyz, splits head/body,
// and outputs them inside a fresh Astro document.

interface Props {
  rawHtml: string;
  lang?: string;
}

const { rawHtml, lang } = Astro.props;

// Extract <html> attributes (lang, data-wf-page, etc.)
const htmlMatch = rawHtml.match(/<html([^>]*)>/i);
const htmlAttrs = htmlMatch?.[1]?.trim() ?? '';

// Extract <head> inner HTML
const headMatch = rawHtml.match(/<head[^>]*>([\s\S]*?)<\/head>/i);
const headHtml = headMatch?.[1] ?? '';

// Extract <body> attributes and inner HTML
const bodyMatch = rawHtml.match(/<body([^>]*)>([\s\S]*?)<\/body>/i);
const bodyAttrsRaw = bodyMatch?.[1]?.trim() ?? '';
const bodyHtml = bodyMatch?.[2] ?? '';

// Parse body attributes → object so Astro renders them correctly
function parseAttrs(s: string): Record<string, string> {
  const out: Record<string, string> = {};
  const re = /([a-zA-Z_:][\w:.-]*)(?:\s*=\s*(?:"([^"]*)"|'([^']*)'|([^\s>]+)))?/g;
  let m;
  while ((m = re.exec(s)) !== null) {
    out[m[1]] = m[2] ?? m[3] ?? m[4] ?? '';
  }
  return out;
}
const bodyAttrs = parseAttrs(bodyAttrsRaw);

// Resolve <html lang>
const htmlAttrsObj = parseAttrs(htmlAttrs);
const resolvedLang = lang ?? htmlAttrsObj.lang ?? 'en';
---
<!DOCTYPE html>
<html lang={resolvedLang} {...Object.fromEntries(Object.entries(htmlAttrsObj).filter(([k]) => k !== 'lang'))}>
  <head>
    <!-- Load Google Fonts via synchronous <link> at the very top of <head>
         so they start downloading before Webflow's JS-based WebFont.load
         runs. This eliminates the FOUT (font swap) the user was seeing on
         page load. display=swap shows fallback immediately, then swaps to
         the custom font as soon as it lands — but with these preconnect
         + stylesheet hints the swap typically happens within the first
         100-200ms, often before the user perceives any flash. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@300;400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@300;400;500;600;700&display=swap"
    />
    <Fragment set:html={headHtml} />
    <!-- Site-wide override on top of the scraped Webflow head.
         is:inline so the rule lands in the HTML and beats Webflow's own
         stylesheet via source order, without any Astro processing.        -->
    <style is:inline>
      /* Logo + hamburger icon: flatten the white SVGs to ~15% gray so they
         read as dark against the light pill nav, with a touch of softness
         vs pure black. */
      .n-logo,
      .n-menu-icn,
      .n-menu-icn-out {
        filter: brightness(0.15) !important;
      }

      /* Bottom-nav pill background: ~15% lighter than Webflow's default. */
      .n-menu-wrap {
        background-color: rgba(255, 255, 255, 0.72) !important;
      }
    </style>
  </head>
  <body {...bodyAttrs}>
    <Fragment set:html={bodyHtml} />
  </body>
</html>
